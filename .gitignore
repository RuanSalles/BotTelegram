# ========================
# 🔐 ENV / SEGURANÇA
# ========================
.env
.env.*
!.env.example

# ========================
# 📦 DEPENDÊNCIAS
# ========================
/vendor/
/node_modules/

# ========================
# 🧪 TESTES / COVERAGE
# ========================
/coverage/
/.phpunit.result.cache

# ========================
# 🧠 CACHE / BUILD
# ========================
/bootstrap/cache/*.php
/bootstrap/cache/*.json
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/debugbar/*

# Ignorar tudo dentro de storage (exceto .gitignore)
!storage/.gitignore

# ========================
# 🐳 DOCKER
# ========================
docker/mysql/data/
docker/mysql/logs/

# ========================
# 🧾 LOGS
# ========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================
# 🖥️ SISTEMA OPERACIONAL
# ========================
.DS_Store
Thumbs.db

# ========================
# 🧑‍💻 IDEs / EDITORES
# ========================

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# PHPStorm / JetBrains
.idea/
*.iml

# Sublime
*.sublime-project
*.sublime-workspace

# ========================
# ⚙️ BUILD FRONTEND
# ========================
/public/build
/public/hot

# ========================
# 🧪 MISC
# ========================
*.swp
*.bak
*.tmp
*.cache

/.phpunit.cache
/.php-cs-fixer.cache
/.pest.cache
